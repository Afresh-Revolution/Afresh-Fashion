DATABASE_URL=postgresql://user:password@host:5432/postgres
SESSION_SECRET=generate_a_random_string_at_least_32_chars

# Backblaze B2 (S3-compatible) — copy endpoint from bucket settings, not from key ID prefix
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
# Optional: friendly download base (https://fXXX.backblazeb2.com/file/your-bucket)
B2_PUBLIC_BASE_URL=
